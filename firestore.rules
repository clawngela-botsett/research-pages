rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tasks: open read/write (app has its own password gate)
    match /tasks/{taskId} {
      allow read, write: if true;
    }
    // Everything else requires auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
